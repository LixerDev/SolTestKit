{
  "name": "@lixerdev/soltestkit",
  "version": "1.0.0",
  "description": "TypeScript testing framework for Anchor programs — pre-built mocks for wallets, tokens, oracles, and CPIs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 examples/**/*.test.ts",
    "test:basic": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 examples/basic.test.ts",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "solana", "anchor", "testing", "framework", "mock", "spl-token", "pyth", "switchboard"
  ],
  "author": "LixerDev",
  "license": "MIT",
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.28.0",
    "@solana/web3.js": ">=1.90.0",
    "@solana/spl-token": ">=0.4.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "chai": "^4.3.4"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
